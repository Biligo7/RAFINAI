# Vite dev-server proxy target. In Docker / Azure the Nginx proxy uses
# BACKEND_BASE_URL on the frontend container.
VITE_BACKEND_URL=http://localhost:3000

# Supabase (auth only — data goes through the Python backend)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
