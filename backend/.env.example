PORT=3000
APP_NAME=RAFINAI
APP_ENV=local
LOG_LEVEL=info

# mock | azure_openai | openai_compatible
AI_PROVIDER=mock
AI_MODEL=mock-gpt
AI_SYSTEM_PROMPT=You are RAFINAI, an AI-powered sustainable trail companion for Greece.
AI_TEMPERATURE=0.4
AI_MAX_TOKENS=2000
AI_MAX_HISTORY_MESSAGES=20
AI_MAX_INPUT_CHARS=12000

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-10-21

# OpenAI-compatible endpoint
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=

# Postgres (local docker-compose, or Azure Postgres Flexible Server)
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=ai_chat
PG_USER=ai_chat
PG_PASSWORD=ai_chat
PG_SSL=false
RUN_MIGRATIONS_ON_STARTUP=true

# Feature flags
AUTH_ENABLED=false
