PORT=3000
APP_NAME="Local Host"
APP_ENV=local
LOG_LEVEL=info

# mock | azure_openai | openai_compatible
# If AI_PROVIDER is mock but OPENAI_API_KEY is set, the backend uses OpenAI anyway.
# This file lives in the backend/ folder and is loaded from there (not from your shell CWD).
AI_PROVIDER=openai_compatible
AI_MODEL=gpt-4o-mini
AI_SYSTEM_PROMPT=You are local host, an AI-powered sustainable trail companion for Greece.
AI_TEMPERATURE=0.4
AI_MAX_TOKENS=2000
AI_MAX_HISTORY_MESSAGES=20
AI_MAX_INPUT_CHARS=12000

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-10-21

# Official OpenAI API (set AI_PROVIDER=openai_compatible). Leave OPENAI_BASE_URL empty for api.openai.com.
# If OPENAI_BASE_URL is set, use the full API base including /v1 (e.g. https://api.openai.com/v1).
# Outbound HTTPS from Docker can fail behind strict firewalls — set HTTP_PROXY / HTTPS_PROXY here if needed.
# Values must include a scheme, e.g. http://proxy.company.com:8080. Empty HTTP(S)_PROXY from the host breaks httpx.
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini

# Postgres (local docker-compose, or Azure Postgres Flexible Server)
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=ai_chat
PG_USER=ai_chat
PG_PASSWORD=ai_chat
PG_SSL=false
RUN_MIGRATIONS_ON_STARTUP=true

# Feature flags
AUTH_ENABLED=true
