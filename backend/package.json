{
  "name": "azure-ai-chat-backend",
  "version": "1.0.0",
  "private": true,
  "description": "Azure AI Chat backend API (Express + TypeScript + Azure SQL).",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json && cp src/db/schema.sql dist/db/schema.sql",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "db:migrate": "tsx src/db/migrate-cli.ts"
  },
  "dependencies": {
    "compression": "1.8.1",
    "dotenv": "16.4.5",
    "express": "4.21.2",
    "helmet": "8.1.0",
    "openai": "4.69.0",
    "pg": "8.13.0",
    "pino": "9.14.0",
    "pino-http": "10.5.0",
    "uuid": "10.0.0",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/compression": "1.8.1",
    "@types/express": "4.17.21",
    "@types/node": "20.19.40",
    "@types/pg": "8.11.10",
    "@types/uuid": "10.0.0",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vitest": "2.1.9"
  },
  "engines": {
    "node": ">=20"
  }
}
